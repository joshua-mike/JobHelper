# Copy this file to ".env" and fill in what you have. Everything here is OPTIONAL
# for the first run — the pipeline produces a digest with no keys at all.

# Enables Claude-powered job scoring + resume/cover-letter tailoring.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model overrides (defaults are sensible; uncomment to change).
# JOBHELPER_JUDGE_MODEL=claude-sonnet-4-6
# JOBHELPER_TAILOR_MODEL=claude-opus-4-8
