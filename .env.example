# Copy this file to ".env" and fill in what you have. Everything here is OPTIONAL
# for the first run — the pipeline produces a digest with no keys at all.

# Enables Claude-powered job scoring + resume/cover-letter tailoring.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model overrides (defaults are sensible; uncomment to change).
# JOBHELPER_JUDGE_MODEL=claude-sonnet-4-6
# JOBHELPER_TAILOR_MODEL=claude-opus-4-8

# Semantic scoring downloads its embedding model once, then runs from local
# cache. AFTER your first successful semantic run, uncomment this to skip the
# per-run Hugging Face update-check (silences the "unauthenticated requests"
# warning; no HF account/token is ever needed). Don't enable it before the model
# has downloaded — it blocks the download and scoring silently falls back to
# lexical mode. Set back to 0 if you ever switch embedding models.
# HF_HUB_OFFLINE=1
